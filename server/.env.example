# Server configuration port
PORT=5000

# SMTP Provider configuration (e.g., SMTP server hostname)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP Auth credentials
# IMPORTANT: For Gmail, use an "App Password" rather than your primary Google Account password.
# Guide to set up Gmail App Password: https://support.google.com/accounts/answer/185833
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Recipient configuration
# This is the email address where submissions will be delivered in real-time.
CONTACT_RECEIVER=your-destination-email@gmail.com
